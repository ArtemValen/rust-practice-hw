fn main() {
    // Приклад: висоти стовпців шириною в 1 одиницю
    let data = vec![1, 0, 5, 2, 6, 3, 10];
    
    let area = area_occupied(&data);
    
    println!("Дані висот: {:?}", data);
    println!("Загальна зайнята площа: {}", area);
}

/// Функція розраховує зайняту площу.
/// Оскільки ширина кожного стовпця зазвичай дорівнює 1,
/// то площа — це просто сума всіх висот.
fn area_occupied(data: &Vec<u32>) -> u32 {
    // Використовуємо ітератор для підсумовування значень
    data.iter().sum()
}

