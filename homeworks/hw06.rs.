fn main() {
    // Єдиний параметр конфігурації — кількість трикутників (ярусів)
    const TRIANGLES: usize = 3;

    for t in 0..TRIANGLES {
        // Висота кожного наступного трикутника збільшується для гарного вигляду
        let height = t + 2;
        // Загальна ширина для центрування (базується на найбільшому трикутнику)
        let max_width = TRIANGLES + 1;

        for i in 0..height {
            // Використовуємо ітератори для створення рядка пробілів та зірочок
            let spaces = (0..(max_width - i)).map(|_| " ").collect::<String>();
            let stars = (0..(2 * i + 1)).map(|_| "*").collect::<String>();
            
            println!("{}{}", spaces, stars);
        }
    }
}
