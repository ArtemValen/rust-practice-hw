fn main() {
    let number = 29; // Число для перевірки

    if is_prime(number) {
        println!("Число {} є простим!", number);
    } else {
        println!("Число {} не є простим.", number);
    }
}

fn is_prime(n: u64) -> bool {
    if n <= 1 {
        return false;
    }
    if n <= 3 {
        return true;
    }
    if n % 2 == 0 || n % 3 == 0 {
        return false;
    }

    // Перевіряємо дільники від 5 до корня з n
    // Використовуємо крок 6 (всі прості числа > 3 мають вигляд 6k ± 1)
    let mut i = 5;
    while i * i <= n {
        if n % i == 0 || n % (i + 2) == 0 {
            return false;
        }
        i += 6;
    }

    true
}
